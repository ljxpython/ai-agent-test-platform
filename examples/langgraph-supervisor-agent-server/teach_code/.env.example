# LangGraph 实战教程环境变量配置
# 复制此文件为 .env 并填入你的 API 密钥

# ===== 必需配置 =====

# DeepSeek API 密钥（必需）
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# ===== 可选配置 =====

# OpenAI API 密钥（可选，用于对比测试）
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key-here

# Tavily 搜索 API 密钥（可选，用于搜索功能）
# 获取地址: https://tavily.com/
TAVILY_API_KEY=your-tavily-api-key-here

# ===== 高级配置 =====

# LLM 配置
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.0

# 日志级别
LOG_LEVEL=INFO

# 超时设置（秒）
REQUEST_TIMEOUT=30

# ===== MCP 服务器配置 =====

# 图表 MCP 服务器 URL（如果使用）
CHART_MCP_URL=http://localhost:1122/sse

# 数学 MCP 服务器配置（如果使用）
MATH_MCP_COMMAND=python
MATH_MCP_ARGS=./examples/math_server.py

# ===== 数据库配置 =====

# SQLite 数据库路径
SQLITE_DB_PATH=./data/langgraph.db

# ===== 注意事项 =====
# 1. 不要将包含真实 API 密钥的 .env 文件提交到版本控制
# 2. DeepSeek API 密钥是运行大部分示例的必需配置
# 3. 其他 API 密钥是可选的，缺少时会使用模拟功能
# 4. 确保 API 密钥有足够的配额和权限
