# ==================== 最小可运行模板 ====================
# 这里只保留本地可运行后端时最值得显式设置的变量。
# 默认按 PostgreSQL 本地开发场景编写。

# LangGraph 运行时服务地址。
# 如果你的运行时就是默认本地 `127.0.0.1:8123`，这一项也可以不写。
LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:8123

# 是否启用平台数据库。
# 自建认证、用户、项目、成员关系、审计日志都依赖它。
PLATFORM_DB_ENABLED=true

# 启动时自动建核心表。
# 本地首次启动建议设为 `true`；后续若统一用迁移管理，可改为 `false`。
PLATFORM_DB_AUTO_CREATE=true

# SQLAlchemy 使用的 PostgreSQL 连接串。
# 如果你走本地 PostgreSQL，常见端口是 `5432`；如果你走 SSH 隧道联调远端 PostgreSQL，常见端口是 `15432`。
DATABASE_URL=postgresql+psycopg://agent:<pg-password>@127.0.0.1:5432/agent_platform

# 是否暴露 `/docs`、`/redoc`、`/openapi.json`。
API_DOCS_ENABLED=true

# 自建认证使用的 JWT 签名密钥。
# 除临时本地环境外，都应该替换为强随机值。
JWT_ACCESS_SECRET=local-access-secret-change-me
JWT_REFRESH_SECRET=local-refresh-secret-change-me

# ==================== 按需开启的可选项 ====================
# 只有在你确实需要覆盖默认行为时，才去掉前面的 `#`。

# 本地完全关闭登录校验。
# AUTH_REQUIRED=false
# LANGGRAPH_AUTH_REQUIRED=false

# 对 LangGraph 资源启用项目归属校验。
# LANGGRAPH_SCOPE_GUARD_ENABLED=true

# 如果上游 LangGraph 要求 `x-api-key`，再设置这一项。
# LANGGRAPH_UPSTREAM_API_KEY=

# 动态图参数发现时，自定义 graph 源码根目录。
# LANGGRAPH_GRAPH_SOURCE_ROOT=/absolute/path/to/graph_src_v2
