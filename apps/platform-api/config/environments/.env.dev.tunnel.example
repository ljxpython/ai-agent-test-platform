# ==================== Runtime proxy ====================
# Use local 8123 tunnel to remote runtime 8123
LANGGRAPH_UPSTREAM_URL=http://127.0.0.1:8123
LANGGRAPH_UPSTREAM_API_KEY=

# ==================== App ====================
PROXY_TIMEOUT_SECONDS=300
PROXY_CORS_ALLOW_ORIGINS=*
PROXY_UPSTREAM_RETRIES=1
PROXY_LOG_LEVEL=INFO
API_DOCS_ENABLED=true

# Strict auth for remote-infra dev via SSH tunnel
AUTH_REQUIRED=true
LANGGRAPH_AUTH_REQUIRED=true
LANGGRAPH_SCOPE_GUARD_ENABLED=true

# ==================== Database ====================
PLATFORM_DB_ENABLED=true
PLATFORM_DB_AUTO_CREATE=false
DATABASE_URL=postgresql+psycopg://agent:<pg-password>@127.0.0.1:15432/agent_platform

# ==================== Self-hosted auth ====================
JWT_ACCESS_SECRET=<set-a-local-dev-secret>
JWT_REFRESH_SECRET=<set-a-local-dev-secret>
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=604800

# ==================== Bootstrap admin ====================
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=<set-a-local-dev-password>

# ==================== Logging ====================
LOGS_DIR=logs
BACKEND_LOG_FILE=backend.log
BACKEND_LOG_MAX_BYTES=10485760
BACKEND_LOG_BACKUP_COUNT=5

# ==================== Optional graph schema source ====================
# LANGGRAPH_GRAPH_SOURCE_ROOT=/absolute/path/to/graph_src_v2
