# ==================== Runtime proxy ====================
LANGGRAPH_UPSTREAM_URL=https://langgraph.example.com
LANGGRAPH_UPSTREAM_API_KEY=

# ==================== App ====================
PROXY_TIMEOUT_SECONDS=300
PROXY_CORS_ALLOW_ORIGINS=https://app.example.com
PROXY_UPSTREAM_RETRIES=1
PROXY_LOG_LEVEL=INFO
API_DOCS_ENABLED=false
AUTH_REQUIRED=true
LANGGRAPH_AUTH_REQUIRED=true
LANGGRAPH_SCOPE_GUARD_ENABLED=true

# ==================== Database ====================
PLATFORM_DB_ENABLED=true
PLATFORM_DB_AUTO_CREATE=false
DATABASE_URL=postgresql+psycopg://agent:${DB_PASSWORD}@prod-pg:5432/agent_platform

# ==================== Self-hosted auth ====================
JWT_ACCESS_SECRET=${JWT_ACCESS_SECRET}
JWT_REFRESH_SECRET=${JWT_REFRESH_SECRET}
JWT_ACCESS_TTL_SECONDS=1800
JWT_REFRESH_TTL_SECONDS=604800

# ==================== Bootstrap admin ====================
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=${BOOTSTRAP_ADMIN_PASSWORD}

# ==================== Logging ====================
LOGS_DIR=logs
BACKEND_LOG_FILE=backend.log
BACKEND_LOG_MAX_BYTES=10485760
BACKEND_LOG_BACKUP_COUNT=5

# ==================== Optional graph schema source ====================
# LANGGRAPH_GRAPH_SOURCE_ROOT=/opt/langgraph/graph_src_v2
